# Postgres connection string (Neon/Supabase in prod, local Postgres in dev).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/classlib?schema=public"

# Auth.js — generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-me"
# Public base URL of the app (prod: https://classlib.app). Optional locally.
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: Vercel Blob for suggestion asset uploads (Phase 4+).
BLOB_READ_WRITE_TOKEN=""
